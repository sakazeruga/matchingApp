# Database
DB_DSN=mysql:host=127.0.0.1;dbname=amagumo;charset=utf8mb4
DB_USER=root
DB_PASS=

# Gemini API
GEMINI_API_KEY=

# Mail (PHP mail() の From アドレス)
MAIL_FROM=noreply@example.com
# 新規申請時に通知を受け取る管理者メールアドレス
MAIL_ADMIN=admin@example.com

# 管理画面ログイン
ADMIN_USER=admin
# 以下のコマンドでハッシュ生成: php -r "echo password_hash('YOUR_PASSWORD', PASSWORD_DEFAULT);"
ADMIN_PASS_HASH=
